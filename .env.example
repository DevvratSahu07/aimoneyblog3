# PostgreSQL connection string
# Local example:
# DATABASE_URL=postgres://user:password@localhost:5432/ai_money_blog
# Supabase pooler example:
# DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://user:password@localhost:5432/ai_money_blog

# Password used to sign in to /admin/login (also acts as the admin API token).
# Generate with: openssl rand -hex 24
ADMIN_PASSWORD=change-me-please

# Random secret used by the API for session signing.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-too

# Optional: restrict API CORS to your frontend origin(s).
# Comma-separate multiple origins, e.g. https://your-app.vercel.app,https://www.yourdomain.com
# CORS_ORIGIN=https://your-app.vercel.app

# Optional: when the frontend is deployed on a different origin, point it at the live API.
# Example: VITE_API_URL=https://your-render-service.onrender.com
# VITE_API_URL=

# Optional: API server port (default 8080)
# PORT=8080
